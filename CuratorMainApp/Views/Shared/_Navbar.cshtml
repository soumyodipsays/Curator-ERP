@* Views/Shared/_Navbar.cshtml *@
<nav class="apple-nav">
    <div class="container-xl px-4 d-flex align-items-center justify-content-between w-100">

        @* Brand *@
        <a href="@Url.Action("Index", "Home")" class="nav-brand">Curator.</a>

        @* Desktop nav links *@
        <div class="d-none d-md-flex align-items-center gap-1">
            <a href="@Url.Action("Index", "Home")"
               class="nav-link-item @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")">Home</a>

            <a href="@Url.Action("Home", "Product")"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"].ToString() == "Product" ? "active" : "")">Shop</a>

            <a href="@Url.Action("Index", "Collections")" class="nav-link-item">Collections</a>
            <a href="@Url.Action("Sale", "Products")" class="nav-link-item">Sale</a>
            <a href="@Url.Action("About", "Home")" class="nav-link-item">Journal</a>
        </div>

        @* Icon group *@
        <div class="d-flex align-items-center gap-1">
            <button class="nav-icon-btn d-none d-md-flex" id="nav-search-btn" title="Search">
                <i class="bi bi-search"></i>
            </button>

            <a href="@Url.Action("Index", "Wishlist")" class="nav-icon-btn" title="Wishlist">
                <i class="bi bi-heart"></i>
            </a>

            <a href="@Url.Action("Index", "Cart")" class="nav-icon-btn position-relative" title="Cart">
                <i class="bi bi-bag"></i>
                @if (ViewBag.CartCount != null && (int)ViewBag.CartCount > 0)
                {
                    <span class="cart-badge">@ViewBag.CartCount</span>
                }
            </a>

            @* USER DROPDOWN *@
            <div class="position-relative d-none d-md-flex">

                <!-- Logged Out Button -->
                <a href="@Url.Action("Login","User")"
                   class="nav-icon-btn"
                   id="loginBtn"
                   title="Login">
                    <i class="bi bi-person"></i>
                </a>

                <!-- Logged In Button -->
                <button class="nav-icon-btn d-none"
                        id="userMenuBtn"
                        title="Account"
                        type="button">
                    <i class="bi bi-person-circle"></i>
                </button>

                <!-- Dropdown -->
                <div class="user-dropdown shadow-sm" id="userDropdown">

                    <div class="px-3 py-2 border-bottom small text-muted">
                        Welcome,
                        <span id="navUserName">User</span>
                    </div>

                    <a href="@Url.Action("Profile","User")"
                       class="user-dropdown-item">
                        <i class="bi bi-person-circle me-2"></i>
                        Profile
                    </a>

                    <a href="javascript:void(0)"
                       class="user-dropdown-item text-danger"
                       id="logoutBtn">
                        <i class="bi bi-box-arrow-right me-2"></i>
                        Logout
                    </a>

                </div>

            </div>

            @* Mobile hamburger *@
            <button class="nav-icon-btn d-md-none"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#mobileMenu"
                    aria-controls="mobileMenu">
                <i class="bi bi-list"></i>
            </button>
        </div>
    </div>
</nav>

@* ===== Mobile Offcanvas Menu ===== *@
<div class="offcanvas offcanvas-end apple-offcanvas" tabindex="-1" id="mobileMenu">
    <div class="offcanvas-header">
        <span class="nav-brand">Curator.</span>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body">
        <a href="@Url.Action("Index", "Home")" class="offcanvas-nav-link">Home</a>
        <a href="@Url.Action("Home", "Product")" class="offcanvas-nav-link">Shop</a>
        <a href="@Url.Action("Index", "Collections")" class="offcanvas-nav-link">Collections</a>
        <a href="@Url.Action("Sale", "Products")" class="offcanvas-nav-link">Sale</a>
        <a href="@Url.Action("About", "Home")" class="offcanvas-nav-link">Journal</a>
        <a href="@Url.Action("Index", "Account")" class="offcanvas-nav-link">Profile</a>
        <a href="@Url.Action("Logout", "Account")" class="offcanvas-nav-link text-danger">Logout</a>
    </div>
</div>

@Html.Partial("_SearchOverlay")

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="~/Scripts/search.js"></script>

<style>
    .user-dropdown {
        position: absolute;
        top: 48px;
        right: 0;
        width: 220px;
        background: rgba(255,255,255,0.96);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(0,0,0,.06);
        border-radius: 16px;
        padding: 8px;
        display: none;
        z-index: 9999;
        animation: fadeIn .18s ease;
    }

        .user-dropdown.show {
            display: block;
        }

    .user-dropdown-item {
        display: flex;
        align-items: center;
        padding: 10px 12px;
        border-radius: 12px;
        text-decoration: none;
        color: #111;
        font-size: 14px;
        transition: .2s ease;
    }

        .user-dropdown-item:hover {
            background: rgba(0,0,0,.05);
            color: #111;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>


<script>
    $(function () {
        Auth.ajaxToken();

        const token = Auth.getToken();

        /* LOGIN / LOGOUT NAV STATE */
        if (token) {

            Auth.validate(
                function (res) {

                    // Hide login icon
                    $("#loginBtn").addClass("d-none");

                    // Show logged in icon
                    $("#userMenuBtn").removeClass("d-none");

                    // Show mobile logged in menu
                    $(".mobile-login").addClass("d-none");
                    $(".mobile-user").removeClass("d-none");

                    // Username
                    if (res.userName) {
                        $("#navUserName").text(res.userName);
                    }
                    else if (res.email) {
                        $("#navUserName").text(res.email);
                    }
                },
                function () {
                    showLoggedOut();
                }
            );

        } else {
            showLoggedOut();
        }

        function showLoggedOut() {

            $("#loginBtn").removeClass("d-none");
            $("#userMenuBtn").addClass("d-none");

            $(".mobile-login").removeClass("d-none");
            $(".mobile-user").addClass("d-none");
        }

        /* DESKTOP DROPDOWN */
        $("#userMenuBtn").on("click", function (e) {
            e.stopPropagation();
            $("#userDropdown").toggleClass("show");
        });

        $(document).on("click", function () {
            $("#userDropdown").removeClass("show");
        });

        $("#userDropdown").on("click", function (e) {
            e.stopPropagation();
        });

        /* LOGOUT */
        $("#logoutBtn, #mobileLogoutBtn").on("click", function () {

            Auth.logout(false);

            window.location.href =
                '@Url.Action("Login","User")';
        });

    });
</script>