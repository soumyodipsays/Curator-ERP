<div class="col-12 col-lg-3">
    <div class="filter-sidebar">

        <!-- Brand Filter -->
        <div id="brandContainer">
            <div class="filter-option">
                <input class="form-check-input" type="checkbox" id="brand-all" data-brand="all" checked>
                <label for="b1">All Brands <span class="count">(48)</span></label>
            </div>
        </div>

        <div style="height:1px;background:var(--gray-2);margin:20px 0"></div>

        <!-- Price Range -->
        <span class="filter-title">Price Range</span>
        <div class="price-range">
            <input type="range" min="0" max="10000" value="1000" id="priceRange"
                   oninput="document.getElementById('priceVal').textContent='$'+this.value">
            <div class="price-labels">
                <span>₹0</span>
                <span id="priceVal">₹1000</span>
                <span>₹10000</span>
            </div>
        </div>

        <div style="height:1px;background:var(--gray-2);margin:20px 0"></div>

        <!-- Size Filter -->
        <span class="filter-title">Size</span><!-- {{ product.SizeID }} -->
        <div class="size-chips" style="margin-bottom:0">
            <div class="size-chip active" data-size="all">All</div>
            @*<div class="size-chip">S</div>
            <div class="size-chip">M</div>
            <div class="size-chip">L</div>
            <div class="size-chip">XL</div>
            <div class="size-chip">XXL</div>*@
        </div>

        <div style="height:1px;background:var(--gray-2);margin:20px 0"></div>

        <!-- Status Filter -->
        <span class="filter-title">Availability</span>
        <div class="filter-option"><input class="form-check-input" type="checkbox" id="s1" checked><label for="s1">In Stock <span class="count">(38)</span></label></div><!-- {{ product.IsActive }} -->
        <div class="filter-option"><input class="form-check-input" type="checkbox" id="s2"><label for="s2">Coming Soon <span class="count">(10)</span></label></div>

        <div style="height:1px;background:var(--gray-2);margin:20px 0"></div>

        <button class="btn-apple-blue w-100" id="btn-apply-filters" style="justify-content:center">Apply Filters</button>
        <button class="btn-apple-outline w-100 mt-2" style="justify-content:center;margin-top:10px">Clear All</button>

    </div>
</div>
