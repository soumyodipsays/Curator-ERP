@model Curator.Web.Models.ViewModels.CartViewModel
@using System.Linq

@* Views/Shared/_CartItems.cshtml *@
@* Called from: Views/Cart/Index.cshtml *@

<div id="cart-container"></div>

<script>

function countDisCount(type, realPrice, discount) {
    const validTypes = ["I", "P"];

    if (!validTypes.includes(type)) {
        return "Invalid type";
    }

    return type === "I"
        ? Math.round(realPrice - discount)
        : Math.round(realPrice - (realPrice * discount / 100));
}

async function loadCart(items) {
    // const res = await fetch('/Cart/GetCartItems');
    // const items = await res.json();

    const container = document.getElementById("cart-container");

    if (!items || items.length === 0) {
        container.innerHTML = `
            <div class="text-center py-5">
                <i class="bi bi-bag" style="font-size:3rem;color:var(--gray-3)"></i>
                <h5 class="mt-3">Your bag is empty</h5>
                <a href="/Product" class="btn-apple-blue">Start Shopping</a>
            </div>
        `;
        return;
    }

    container.innerHTML = items.map(item => `
        <div class="cart-item"
             data-cart-id="${item.CartID}"
             data-product-id="${item.ProductID}">

            <div class="cart-item-img">
                <img src="${item.ImageURL}" />
            </div>

            <div class="cart-item-info">
                <div>${item.BrandName}</div>
                <div>${item.ProductName}</div>

                <div>
                    ${item.size ? `Size: ${item.size}` : ""}
                    ${item.color ? ` · ${item.color}` : ""}
                </div>

                <div class="qty-wrapper d-flex align-items-center gap-3 mt-1 flex-wrap">
                    <button class="qty-btn-sm" onclick="changeCartQty(this, -1)">-</button>
                    <span class="qty-num" data-qty=${item.Quantity}>${item.Quantity}</span>
                    <button class="qty-btn-sm" onclick="changeCartQty(this, 1)">+</button>

                    <button class="btn-danger-ghost" onclick="removeItem(${item.CartID})">Remove</button>
                </div>
            </div>

            <div class="d-flex flex-column gap-1">

                    <!-- Discounted Price -->
                    <div class="fw-bold text-success fs-5">
                        ${"₹" + countDisCount(item.IsInrOrPercentage, item.Price, item.Discount)}
                    </div>

                    <!-- Original Price -->
                    ${item.Price ? `
                        <div class="text-muted text-decoration-line-through small">
                            ₹${item.Price}
                        </div>
                    ` : ""}

                    <!-- Discount Badge -->
                    ${item.Discount ? `
                        <div>
                            <span class="badge bg-danger">
                                - ${item.type === "P"
                                ? item.Discount + "%"
                                : "₹" + item.Discount}
                            </span>
                        </div>
                    ` : ""}

                </div>
        </div>
    `).join('');
}

loadCart();
</script>