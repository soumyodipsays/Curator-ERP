@* Views/Shared/_ProfileHeader.cshtml *@

@{
    var avatarUrl = "https://i.pravatar.cc/150?img=12";
    var firstName = "Arjun";
    var lastName = "Mehta";
    var username = "arjun_m";
    var memberSince = "June 2023";
    var totalOrders = 14;
    var wishlistCount = 7;
    var addressCount = 2;
}

<div class="profile-header-card fade-up">

    @*{{!-- Avatar + Identity --}}*@
    <div class="d-flex align-items-center gap-4 flex-wrap">

        @*{{!-- Avatar with camera overlay --}}*@
        <div class="avatar-wrap" onclick="triggerAvatarUpload()" title="Change photo">
            <img src=""
                 alt=""
                 class="avatar-img"
                 id="avatarPreview" />
            <div class="avatar-overlay">
                <i class="bi bi-camera-fill"></i>
            </div>
        </div>
        <input type="file" id="avatarInput" accept="image/*"
               style="display:none" onchange="uploadAvatar(this)" />

        @*{{!-- Name block --}}*@
        <div class="flex-grow-1">
            <div class="profile-name" id="profile-name"></div>
            <div class="profile-handle" id="profile-handle"></div>
            <div class="profile-since">
                <i class="bi bi-calendar3"></i>
                Member since <span id="member-since"></span>
            </div>
        </div>

        @*{{!-- Edit shortcut (desktop) --}}*@
        <a href="#personalSection" class="btn-profile-outline d-none d-md-inline-flex">
            <i class="bi bi-pencil"></i> Edit Profile
        </a>
    </div>

    @*{{!-- Stats strip --}}*@
    <div class="stats-strip">
        <div class="stat-item">
            <span class="stat-num" id="stat-orders"></span>
            <span class="stat-label">Orders</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-num" id="stat-wishlist"></span>
            <span class="stat-label">Saved</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-num" id="stat-addresses"></span>
            <span class="stat-label">Addresses</span>
        </div>
    </div>

</div>


<script>

    function formatDate(rawDateTime) { 
        const timestamp = parseInt(rawDateTime.match(/\d+/)[0]);
        const date = new Date(timestamp);

        const formattedDate = date.toLocaleString('en-US', {
            month: 'long',
            year: 'numeric'
        })
        return formattedDate;
    }

    function renderProfileBasic(firstName, lastName, userName, createdOn, avatar_url) { 

        $("#avatarPreview")
            .attr("src", avatar_url)
            .attr("alt", firstName + " " + lastName);

        $("#profile-name").text(firstName + " " + lastName);
        $("#profile-handle").text("@@" + userName);
        $("#member-since").text(formatDate(createdOn));

    }

    function renderProfileStats(totalOrders, wishlistCount, addressCount) { 
        $("#stat-orders").text(totalOrders);
        $("#stat-wishlist").text(wishlistCount);
        $("#stat-addresses").text(addressCount);
    }
</script>