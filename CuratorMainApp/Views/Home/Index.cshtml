@using System.Configuration
@* Views/Home/Index.cshtml *@
@model Curator.Models.HomeViewModel
@{
    ViewBag.Title = "Home Page";
    var loginUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/Login";
    var registerUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/Register";
    var emailUrl = ConfigurationManager.AppSettings["EmailServiceBaseUrl"] + "/Email/Test";
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* ===== HERO ===== *@
@Html.Partial("_Hero", Model.Hero)

@* ===== BRAND MARQUEE ===== *@
@Html.Partial("_BrandStrip", Model.Brands)

@* ===== CATEGORY PILLS ===== *@
@Html.Partial("_CategoryPills", Model.CategoryPills)

@* ===== FEATURED PRODUCTS ===== *@
@Html.Partial("_FeaturedProducts", Model.FeaturedProducts)

@* ===== FLASH SALE ===== *@
@Html.Partial("_FlashSale", Model.FlashSale)

<form action="@loginUrl" method="post">
    <div>
        <label>Email:</label>
        <input type="text" name="Email" />
    </div>
    <div>
        <label>Password:</label>
        <input type="text" name="password" />
    </div>
    <button type="submit">Login to Auth System</button>
</form>

<form action="@registerUrl" method="post">
    <div>
        <label>Admin Username:</label>
        <input type="text" name="AdminUserName" />
    </div>

    <div>
        <label>Customer ID:</label>
        <input type="number" name="CustomerID" />
    </div>

    <div>
        <label>User ID (0 for new):</label>
        <input type="number" name="UserID" value="0" />
    </div>

    <div>
        <label>Email</label>
        <input type="text" name="Email" />
    </div>

    <div>
        <label>Username:</label>
        <input type="text" name="UserName" />
    </div>

    <div>
        <label>Password:</label>
        <input type="password" name="Password" />
    </div>

    <div>
        <label>First Name:</label>
        <input type="text" name="FirstName" />
    </div>

    <div>
        <label>Last Name:</label>
        <input type="text" name="LastName" />
    </div>

    <button type="submit">Register User</button>
</form>
@* ===== TOP RATED ===== *@
@Html.Partial("_TopRated", Model.TopRatedProducts)

@* ===== NEWSLETTER ===== *@
@Html.Partial("_Newsletter")

@section scripts {
    <script src="~/Scripts/curator.js"></script>
}
