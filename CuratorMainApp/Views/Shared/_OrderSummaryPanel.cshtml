@model Curator.Web.Models.ViewModels.OrderSummaryPanelViewModel

@* Views/Shared/_OrderSummaryPanel.cshtml *@
@* Reused on: Cart, Address, Review pages (sticky sidebar) *@
@* Maps: tblOrder — Amount, DiscountAmount, CouponAmount, PaymentAmount *@
@using System.Configuration

@{
    var productURL = ConfigurationManager.AppSettings["ProductServiceBaseUrl"];
    var baseURL = ConfigurationManager.AppSettings["CuratorMainAppBaseUrl"];
    var couponCodeURL = productURL + "/Products/ValidateCoupon";
}

<div class="summary-card">

    <h6 style="font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gray-4);margin-bottom:16px">
        Order Summary
    </h6>

    @* Coupon input (Cart page only) *@
    @if (Model.ShowCouponInput)
    {
        <div class="coupon-wrap">
            <input class="coupon-input"
                   type="text"
                   placeholder="Coupon code"
                   id="couponInput"
                   value="@Model.AppliedCouponCode" />

            <button type="button"
                    class="btn-coupon"
                    id="btnApplyCoupon">
                Apply
            </button>
        </div>

        <div id="couponMsg"
             style="font-size:.75rem;margin-bottom:12px;display:none">
        </div>
    }

    <div class="summary-row">
        <span class="summary-label">
            Subtotal (@Model.ItemCount items)
        </span>

        <span class="summary-value green">
            ₹<span id="sub-total-amt"></span>
        </span>
    </div>

    @if (Model.DiscountAmount > 0)
    {
        <div class="summary-row">
            <span class="summary-label">Product Discount</span>

            <span class="summary-value green" id="discountAmt">
                - ₹<span id="discountAmt-span"></span>
            </span>
        </div>
    }

    <div class="summary-row"
         id="couponRow"
         @(Model.CouponAmount > 0 ? "" : "style='display:none'")>

        <span class="summary-label">Coupon Savings</span>

        <span class="summary-value green">
            - ₹<span id="couponAmt">0.00</span>
        </span>
    </div>

    <div class="summary-row">
        <span class="summary-label">Delivery</span>

        <span class="summary-value green" id="deliveryFee2">
            @(Model.DeliveryFee == 0
                ? "FREE"
                : "$" + Model.DeliveryFee.ToString("N0"))
        </span>
    </div>

    <div class="apple-divider"></div>

    <div class="summary-row total">
        <span>Total</span>

        <span id="totalAmt">
            ₹ <span id="total-amt-span"></span>
        </span>
    </div>

    <div style="height:16px"></div>

    <!-- ========================= -->
    <!-- STEP 1 -->
    <!-- ========================= -->

    <div id="step1-section" class="checkout-step-section">

        <button onclick="proceedToCheckout()" class="btn-apple-blue" style="width:100%; border:none; cursor:pointer;">
            Proceed to Delivery <i class="bi bi-arrow-right"></i>
        </button>

        <a href="@baseURL/Product/Home"
           class="btn-apple-ghost mt-2"
           style="display:flex;align-items:center;justify-content:center;gap:6px;margin-top:10px;border-radius:980px;padding:12px;font-size:.85rem;font-weight:500;color:var(--black)">

            <i class="bi bi-arrow-left"></i>
            Continue Shopping

        </a>

    </div>

    <!-- ========================= -->
    <!-- STEP 2 -->
    <!-- ========================= -->

    <div id="step2-section"
         class="checkout-step-section"
         style="display:none">

        <div style="margin-bottom:16px">

            <div style="font-size:.72rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--gray-4);margin-bottom:10px">

                <span id="bag-item-count">
                    @Model.ItemCount
                </span>
                Items in Bag

            </div>

            <div id="bag-images"
                 style="display:flex;gap:8px;flex-wrap:wrap">

                @foreach (var img in Model.ItemImageUrls)
                {
                    <img src="@img"
                         style="width:48px;height:48px;border-radius:10px;object-fit:cover" />
                }

            </div>
        </div>

        <a href="/CuratorMainApp/Checkout/Review"
           class="btn-apple-blue">

            Review Order
            <i class="bi bi-arrow-right"></i>

        </a>

    </div>

    <!-- ========================= -->
    <!-- STEP 3 -->
    <!-- ========================= -->

    <div id="step3-section"
         class="checkout-step-section"
         style="display:none">

        <a href="/CuratorMainApp/Checkout/Payment"
           class="btn-apple-blue"
           style="font-size:1rem;padding:16px">

            <i class="bi bi-lock-fill"></i>
            Proceed to Payment

        </a>

        <p style="font-size:.7rem;color:var(--gray-4);text-align:center;margin-top:10px">

            By placing your order you agree to our

            <a href="/terms" style="color:var(--blue)">
                Terms
            </a>

            &

            <a href="/privacy" style="color:var(--blue)">
                Privacy Policy
            </a>

        </p>

        <div style="text-align:center;margin-top:4px">

            <span style="font-size:.65rem;color:var(--gray-4);display:block;margin-bottom:8px;letter-spacing:.06em;text-transform:uppercase">

                We accept

            </span>

            <div style="display:flex;justify-content:center;gap:8px;flex-wrap:wrap">

                <span style="background:var(--gray-1);border-radius:6px;padding:4px 10px;font-size:.7rem;font-weight:700;color:var(--gray-5)">VISA</span>

                <span style="background:var(--gray-1);border-radius:6px;padding:4px 10px;font-size:.7rem;font-weight:700;color:var(--gray-5)">MC</span>

                <span style="background:var(--gray-1);border-radius:6px;padding:4px 10px;font-size:.7rem;font-weight:700;color:var(--gray-5)">UPI</span>

                <span style="background:var(--gray-1);border-radius:6px;padding:4px 10px;font-size:.7rem;font-weight:700;color:var(--gray-5)">COD</span>

                <span style="background:var(--gray-1);border-radius:6px;padding:4px 10px;font-size:.7rem;font-weight:700;color:var(--gray-5)">NetBanking</span>

            </div>
        </div>

    </div>

    <!-- TRUST STRIP -->

    <div class="trust-strip">

        <span class="trust-badge">
            <i class="bi bi-shield-check"></i>
            Secure
        </span>

        <span class="trust-badge">
            <i class="bi bi-arrow-return-left"></i>
            Returns
        </span>

        <span class="trust-badge">
            <i class="bi bi-truck"></i>
            Free delivery
        </span>

    </div>

</div>


<script>
    function calculateSubTotal(CART_ITEMS) {
        const initialAmount = 0;
        const subTotal = CART_ITEMS.reduce(
            (acc, currVal) => acc + (currVal.Price * currVal.Quantity),
            initialAmount
        );

        console.log("Subtotal: ", subTotal);
        return subTotal;
    }

    function calculateDiscountedPrice(CART_ITEMS) {
        const initialDiscountAmount = 0;
        const totalDiscountAmount = CART_ITEMS.reduce(
            (acc, currVal) => acc + (countDiscount(currVal.IsInrOrPercentage, currVal.Price, currVal.Discount,currVal.Quantity)),
            initialDiscountAmount
        );

        console.log("Discount total: ", totalDiscountAmount);
        return totalDiscountAmount;
    }

    function renderSummaryCard(CART_ITEMS) {
        // Failsafe: if the array is empty or undefined, do nothing
        if (!CART_ITEMS || CART_ITEMS.length === 0) return;

        const subtotal = calculateSubTotal(CART_ITEMS);
        const totalDiscountPrice = calculateDiscountedPrice(CART_ITEMS);

        const totalDiscount = subtotal - totalDiscountPrice;

        // Update the HTML spans and lock to 2 decimal places
        $('#sub-total-amt').text(subtotal.toFixed(2));
        $('#discountAmt-span').text(totalDiscount.toFixed(2));
        $('#total-amt-span').text(totalDiscountPrice.toFixed(2));
}


    // RENDER CHECKOUT STEP
    function renderCheckoutStep(currentStep) {

        // Hide all first
        $('.checkout-step-section').hide();

        // Show current step
        if (currentStep === 1) {
            $('#step1-section').show();
        }
        else if (currentStep === 2) {
            $('#step2-section').show();
        }
        else if (currentStep === 3) {
            $('#step3-section').show();
        }
}
    async function syncCartWithServer() {
    if (!CART_ITEMS || CART_ITEMS.length === 0) return;

    try {
        // 1. Prepare the JSON array
        const itemsArray = CART_ITEMS.map(item => ({
            CartID: item.CartID,
            Quantity: item.Quantity,

        }));

        // 2. Prepare the payload matching your C# CartInsertIpdateDTO
        const payload = {
            UserID: Auth.currentUser().userId,
            UserName: Auth.currentUser().UserName,
            CartItemsJSON: JSON.stringify(itemsArray)
        };

        console.log(payload)

        // 3. Let ASP.NET generate the bulletproof URL!
        const endpointUrl = '@productURL/Cart/SyncCartBulk';

        console.log(endpointUrl)
        // 4. Send the request
        const response = await fetch(endpointUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        });

        if (!response.ok) {
            throw new Error(`Server error: ${response.status}`);
        }

        const data = await response.json();

        if (data.success) {
            console.log("Cart bulk update successful!");
        } else {
            console.error("Server logic error:", data.message);
        }
    } catch (error) {
        console.error("Failed to sync cart with backend:", error);
        throw error;
    }
}
    async function proceedToCheckout() {
        const btn = document.querySelector('#step1-section button');
        const originalText = btn.innerHTML;
        btn.innerHTML = 'Saving... <i class="bi bi-hourglass-split"></i>';
        btn.disabled = true;

        try {
            await syncCartWithServer();
            sessionStorage.setItem('CHECKOUT_CART_STATE', JSON.stringify(CART_ITEMS));
            // Redirect after successful save
            window.location.href = "/CuratorMainApp/Checkout/Address";
        } catch (error) {
            btn.innerHTML = originalText;
            btn.disabled = false;
            alert("There was an issue saving your cart. Please try again.");
        }
    }

    function applyCoupon() {

        console.log("applyCoupon called");
        console.log("CART_ITEMS: ", CART_ITEMS);
        const couponCode = $('#couponInput').val().trim();


        // VALIDATIONS
        if (!couponCode) {
            $('#couponMsg')
                .show()
                .css('color', 'red')
                .text('Please enter a coupon code.');

            return;
        }

        if (CART_ITEMS.length === 0) {
            $('#couponMsg')
                .show()
                .css('color', 'red')
                .text('Cart is empty.');
            return;
        }

        try {
            // CART CALCULATIONS
            const subtotal = calculateSubTotal(CART_ITEMS);

            // after product discounts
            const discountedTotal = calculateDiscountedPrice(CART_ITEMS);

            // payable amount before coupon
            const cartTotal = discountedTotal;

            // PAYLOAD
            const payload = {
                CustomerID: 1, // HARDCODED
                CouponCode: couponCode,
                CartTotal: cartTotal
            };

            console.log("Coupon payload:", payload);

            // AJAX CALL
            $.ajax({
                url: `@couponCodeURL`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),

                beforeSend: function () {
                    $('#couponMsg')
                        .show()
                        .css('color', '#666')
                        .text('Applying coupon...');
                },

                success: function (data) {

                    console.log("Coupon response:", data);

                    // INVALID COUPON
                    if (!data.IsValid) {

                        $('#couponMsg')
                            .show()
                            .css('color', 'red')
                            .text(data.ReturnMessage || 'Invalid coupon.');

                        $('#couponRow').hide();

                        // Reset total amount
                        $('#total-amt-span')
                            .text(cartTotal.toFixed(2));

                        return;
                    }

                    // VALID COUPON
                    const couponDiscount =
                        parseFloat(data.CalculatedDiscountAmount || 0);

                    const finalTotal =
                        cartTotal - couponDiscount;

                    // Show coupon row
                    $('#couponRow').show();

                    // Coupon savings
                    $('#couponAmt')
                        .html(`${couponDiscount.toFixed(2)}`);

                    // Final total
                    $('#total-amt-span')
                        .text(finalTotal.toFixed(2));

                    // Success message
                    $('#couponMsg')
                        .show()
                        .css('color', 'green')
                        .text(data.ReturnMessage || 'Coupon applied successfully.');

                    // Save coupon in session
                    sessionStorage.setItem(
                        'APPLIED_COUPON',
                        JSON.stringify({
                            CouponCode: couponCode,
                            CouponID: data.CouponID,
                            DiscountAmount: couponDiscount
                        })
                    );

                    console.log("Coupon applied successfully");
                },

                error: function (xhr, status, error) {

                    console.error("Coupon apply failed");

                    console.error("XHR:", xhr);
                    console.error("Status:", status);
                    console.error("Error:", error);

                    $('#couponMsg')
                        .show()
                        .css('color', 'red')
                        .text('Something went wrong while applying coupon.');
                }
            });

        }
        catch (error) {

            console.error("applyCoupon exception:", error);

            $('#couponMsg')
                .show()
                .css('color', 'red')
                .text('Unexpected error occurred.');
        }
    }
// ============================================
// INITIALIZE ON PAGE LOAD
// ============================================
    document.addEventListener('DOMContentLoaded', () => {

        const btn = document.getElementById('btnApplyCoupon');

        if (btn) {

            btn.addEventListener('click', function () {
                console.log("BUTTON CLICKED");
                applyCoupon();
            });
        }
    // 1. Check if we have saved cart data in sessionStorage
    const savedCart = sessionStorage.getItem('CHECKOUT_CART_STATE');

    if (savedCart) {
        // 2. Restore the global array
        window.CART_ITEMS = JSON.parse(savedCart);

        // 3. Re-render the math and totals
        renderSummaryCard(window.CART_ITEMS);

        // 4. Dynamically update Step 2 UI (since you aren't using the C# model)
        const totalItemsCount = window.CART_ITEMS.reduce((acc, item) => acc + item.Quantity, 0);

        // Update bag count text
        if (document.getElementById('bag-item-count')) {
            document.getElementById('bag-item-count').innerText = totalItemsCount;
        }

        // Inject the images dynamically
        if (document.getElementById('bag-images')) {
            document.getElementById('bag-images').innerHTML = window.CART_ITEMS.map(item => `
                <img src="${item.ImageURL}" style="width:48px;height:48px;border-radius:10px;object-fit:cover" />
            `).join('');
        }
    }

    let currentStep = 1; // Default to Step 1 (Cart)
    const currentUrl = window.location.pathname.toLowerCase();

    if (currentUrl.includes('/address')) {
        currentStep = 2; // We are on the Address page
    } else if (currentUrl.includes('/review') || currentUrl.includes('/payment')) {
        currentStep = 3; // We are on the Review/Payment page
    }

    // Instantly hide the wrong buttons and show the correct ones!
    renderCheckoutStep(currentStep);
});
</script>