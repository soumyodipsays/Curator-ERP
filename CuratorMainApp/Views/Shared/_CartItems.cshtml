@using System.Configuration;
@{ 
    var productURL = ConfigurationManager.AppSettings["ProductServiceBaseUrl"];
}

<div id="cart-container"></div>

<script>
    //global function
    window.loadCart = function (items) {
        CART_ITEMS = items || [];
        renderCart();
    }

    // UI Rendering 
    function renderCart() {
        const container = document.getElementById("cart-container");
        console.log(CART_ITEMS)
        if (!CART_ITEMS || CART_ITEMS.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5">
                    <i class="bi bi-bag" style="font-size:3rem;color:var(--gray-3)"></i>
                    <h5 class="mt-3">Your bag is empty</h5>
                    <a href="/CuratorMainApp/Product/Home" class="btn-apple-blue">Start Shopping</a>
                </div>
            `;
            return;
        }

        container.innerHTML = CART_ITEMS.map(item => `
            <div class="cart-item" data-cart-id="${item.CartID}" data-product-id="${item.ProductID}">

                <div class="cart-item-img">
                    <img src="${item.ImageURL}" alt="${item.ProductName}" />
                </div>

                <div class="cart-item-info">
                    <div>${item.BrandName}</div>
                    <div>${item.ProductName}</div>

                    <div class="text-muted small">
                        ${item.size ? `Size: ${item.size}` : ""}
                        ${item.size && item.color ? ` · ` : ""}
                        ${item.color ? `${item.color}` : ""}
                    </div>

                    <div class="qty-wrapper d-flex align-items-center gap-3 mt-2 flex-wrap">
                        <button class="qty-btn-sm" onclick="window.changeCartQty(${item.CartID}, -1)">-</button>
                        <span class="qty-num">${item.Quantity}</span>
                        <button class="qty-btn-sm" onclick="window.changeCartQty(${item.CartID}, 1)">+</button>

                        <button class="btn-danger-ghost" onclick="window.removeItem(${item.CartID})">
                            Remove
                        </button>
                    </div>
                </div>

                <div class="d-flex flex-column gap-1 text-end">

                    <div class="fw-bold text-success fs-5">
                        ₹${(countDiscount(item.IsInrOrPercentage, item.Price, item.Discount, item.Quantity)).toFixed(2)}
                    </div>

                    ${item.Discount && item.Price ? `
                        <div class="text-muted text-decoration-line-through small">
                            ₹${(item.Price * item.Quantity).toFixed(2)}
                        </div>
                    ` : ""}

                    ${item.Discount ? `
                        <div>
                            <span class="badge bg-danger">
                                - ${String(item.IsInrOrPercentage).trim().toUpperCase() === "P"
                                    ? `${item.Discount}%`
                                    : `₹${item.Discount}`}
                            </span>
                        </div>
                    ` : ""}

                </div>
            </div>
        `).join('');
    }

</script>