@model Curator.Web.Models.ViewModels.CartViewModel
@using System.Linq

@* Views/Shared/_CartItems.cshtml *@
@* Called from: Views/Cart/Index.cshtml *@

@if (Model.Items == null || Model.Items.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-bag" style="font-size:3rem;color:var(--gray-3)"></i>
        <h5 class="mt-3" style="color:var(--gray-4)">Your bag is empty</h5>
        <p style="color:var(--gray-4);font-size:.85rem">Add some items to get started</p>

        <a href="/Product" class="btn-apple-blue" style="width:auto;padding:12px 28px;margin-top:8px">
            <i class="bi bi-bag-heart"></i> Start Shopping
        </a>
    </div>
}
else
{
    foreach (var item in Model.Items)
    {
        <div class="cart-item"
             data-cart-id="@item.CartID"
             data-product-id="@item.ProductID">

            @* Product image *@
            <div class="cart-item-img">
                <img src="@item.ImageURL" alt="@item.ProductName" loading="lazy" />
            </div>

            @* Info *@
            <div class="cart-item-info">

                <div class="cart-item-brand">@item.BrandName</div>

                <div class="cart-item-name">@item.ProductName</div>

                <div class="cart-item-meta">
                    @if (!string.IsNullOrEmpty(item.Size))
                    {
                        <text>Size: @item.Size &nbsp;·&nbsp;</text>
                    }

                    @if (!string.IsNullOrEmpty(item.Color))
                    {
                        <text>@item.Color</text>
                    }
                </div>

                <div class="d-flex align-items-center gap-3 mt-1 flex-wrap">

                    @* Qty stepper *@
                    <div class="qty-stepper-sm">
                        <button class="qty-btn-sm"
                                onclick="changeCartQty(this,-1)"
                                data-cart-id="@item.CartID">
                            −
                        </button>

                        <span class="qty-num">@item.Quantity</span>

                        <button class="qty-btn-sm"
                                onclick="changeCartQty(this,1)"
                                data-cart-id="@item.CartID">
                            +
                        </button>
                    </div>

                    <button class="btn-danger-ghost" onclick="removeItem(this)">
                        <i class="bi bi-trash3"></i> Remove
                    </button>

                    <span class="save-later-badge">Save for later</span>

                </div>
            </div>

            @* Price *@
            <div class="cart-item-price-col">

                <div class="cart-price">$@item.TotalPrice.ToString("N0")</div>

                @if (item.OriginalPrice.HasValue)
                {
                    <div class="cart-price-orig">
                        $@item.OriginalPrice.Value.ToString("N0")
                    </div>
                }

                @if (item.DiscountPct.HasValue && item.DiscountPct > 0)
                {
                    <div class="cart-price-save">-@item.DiscountPct%</div>
                }

            </div>

        </div>
    }
}