@using System.Configuration
@{
    ViewBag.Title = "Product page";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var productURL = ConfigurationManager.AppSettings["ProductServiceBaseUrl"];
    var categoryURL = productURL + "/Products/GetCategoryList";
    var allProductURL = productURL + "/Products/GetProductList";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Curator. — Product Catalog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@700;800;900&display=swap" rel="stylesheet">
    <link href="~/Content/Product.css" rel="stylesheet" />
</head>
<body>

    <!-- Mobile Menu Offcanvas -->
    <div class="offcanvas offcanvas-end apple-offcanvas" id="mobileMenu" tabindex="-1">
        <div class="offcanvas-header">
            <span class="nav-brand">Curator.</span>
            <button class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <a href="index.html" class="offcanvas-nav-link">Shop</a>
            <a href="#" class="offcanvas-nav-link">New Arrivals</a>
            <a href="#" class="offcanvas-nav-link">Trending</a>
            <a href="#" class="offcanvas-nav-link">Collections</a>
            <a href="#" class="offcanvas-nav-link" style="color:var(--blue)">Sale</a>
        </div>
    </div>
    <!-- ===== PARTIAL: _PageHeader.cshtml | model PageHeaderModel ===== -->
    @Html.Partial("_PageHeader")
    <!-- ===== END PARTIAL: _PageHeader.cshtml ===== -->
    <!-- ===== PARTIAL: _CategoryPills.cshtml | model List<CategoryModel> ===== -->
    @Html.Partial("_CategoryPillsProduct")
    <!-- ===== END PARTIAL: _CategoryPills.cshtml ===== -->


    <div class="container-xl px-4 py-4" style="padding-top:28px!important">
        <div class="row g-4">

            <!-- ===== PARTIAL: _FilterSidebar.cshtml | model FilterModel ===== -->
            @Html.Partial("_FilterSidebar")
            <!-- ===== END PARTIAL: _FilterSidebar.cshtml ===== -->
            <!-- ===== Main product grid area ===== -->
            <div class="col-12 col-lg-9">

                <!-- Sort bar -->
                <div class="sort-bar fade-up">
                    <span class="result-count" id="gridResultCount">12 Products</span><!-- {{ products.Count }} -->
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex align-items-center gap-2">
                            <span style="font-size:.82rem;color:var(--gray-4)">Sort by</span>
                            <select class="sort-select" id="sortSelect">
                                <option>Most Popular</option>
                                <option>Price: Low to High</option>
                                <option>Price: High to Low</option>
                                <option>Newest First</option>
                                <option>Top Rated</option>
                            </select>
                        </div>
                        <div class="view-toggle">
                            <button class="view-btn active" id="gridViewBtn" title="Grid view"><i class="bi bi-grid-3x3-gap"></i></button>
                            <button class="view-btn" id="listViewBtn" title="List view"><i class="bi bi-list-ul"></i></button>
                        </div>
                    </div>
                </div>

                <!-- ===== PARTIAL: _ProductGrid.cshtml | model List<ProductModel> ===== -->
                <!-- Replaced via AJAX: $.get('/Product/GetProducts', filters, renderCards) -->
                <div id="productGrid" class="row g-4">
                    <!-- Cards injected by JS (constants now, AJAX later) -->
                    <!-- {% for product in products %} -->
                    <!-- await Html.PartialAsync("_ProductCard", product) -->
                </div>

                <!-- List view (hidden by default) -->
                <div id="productList" class="d-none">
                    <!-- Injected by JS -->
                </div>
                <!-- ===== END PARTIAL: _ProductGrid.cshtml ===== -->
                <!-- No results state -->
                <div id="noResults" class="d-none text-center py-5">
                    <i class="bi bi-search" style="font-size:3rem;color:var(--gray-3)"></i>
                    <h5 class="mt-3" style="color:var(--gray-4)">No products found</h5>
                    <p style="color:var(--gray-4);font-size:.85rem">Try adjusting your filters</p>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-5" id="paginationWrap">
                    <nav>
                        <ul class="pagination gap-2" style="--bs-pagination-border-radius:980px">
                            <li class="page-item disabled">
                                <a class="page-link" style="border-radius:980px;border:1.5px solid var(--gray-2);color:var(--gray-4)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            <li class="page-item active">
                                <a class="page-link" style="border-radius:980px;background:var(--black);border-color:var(--black)">1</a>
                            </li>
                            <li class="page-item"><a class="page-link" style="border-radius:980px;border:1.5px solid var(--gray-2);color:var(--black)">2</a></li>
                            <li class="page-item"><a class="page-link" style="border-radius:980px;border:1.5px solid var(--gray-2);color:var(--black)">3</a></li>
                            <li class="page-item">
                                <a class="page-link" style="border-radius:980px;border:1.5px solid var(--gray-2);color:var(--black)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>

            </div>
        </div>
    </div>


    <!-- ===== PARTIAL: _ProductDetailModal.cshtml | model ProductModel ===== -->
    <!-- Populated dynamically via JS / AJAX: $.get('/Product/Detail/'+id, renderModal) -->
    @Html.Partial("_ProductDetailModal")
    <!-- ===== END PARTIAL: _ProductDetailModal.cshtml ===== -->
    <!-- Toast notification -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;bottom:80px!important">
        <div id="cartToast" class="toast apple-toast" role="alert">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-bag-check-fill" style="color:#30b94d"></i>
                <span id="toastMsg">Added to bag!</span>
            </div>
        </div>
    </div>

    <!-- ===== PARTIAL: _BottomNav.cshtml | model NavViewModel ===== -->
    <div class="ios-tab-bar">
        <div class="d-flex justify-content-around align-items-center px-2">
            <a href="index.html" class="tab-item"><i class="bi bi-house"></i><span>Home</span></a>
            <a href="#" class="tab-item active"><i class="bi bi-grid-3x3-gap"></i><span>Shop</span></a>
            <a href="#" class="tab-item position-relative"><i class="bi bi-bag"></i><span class="tab-badge" id="tabBadge">0</span><span>Bag</span></a>
            <a href="#" class="tab-item"><i class="bi bi-heart"></i><span>Saved</span></a>
            <a href="#" class="tab-item"><i class="bi bi-person"></i><span>Profile</span></a>
        </div>
    </div>
    <!-- ===== END PARTIAL: _BottomNav.cshtml ===== -->


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        /* =============================================
           curator.js — Move to wwwroot/js/curator.js in MVC
           ============================================= */

        /* -----------------------------------------------
           PRODUCT DATA — Constants (replace with AJAX later)
           In MVC: $.get('/Product/GetProducts', filters, renderCards)
           Maps directly to tblProduct columns
           ----------------------------------------------- */
        

        let cartCount = 0;
        let currentQty = 1;
        let isGridView = true;
        let PRODUCTS;

        let CURRENT_PRODUCT = null;
        let SELECTED_SIZE = null;
        let SELECTED_COLOR = null;

        function calculatePrice(p) {
            const isPercentage = p.IsInrOrPercentage == 'P';


            let originalPrice = p.Price;
            let discountAmount = 0;
            let finalPrice = p.Price;

            if (p.DiscountID) {
                discountAmount = isPercentage
                    ? (p.Price * p.Percentage) / 100
                    : p.INR;

                discountAmount = Math.round(discountAmount);
                finalPrice = Math.round(p.Price - discountAmount);
            }

            return {
                originalPrice,
                discountAmount,
                finalPrice
            };
        }
        /* -----------------------------------------------
           RENDER CARDS — _ProductCard.cshtml equivalent
           In MVC: this logic lives in the Partial View + Controller
           AJAX endpoint: GET /Product/GetProducts?category=&brand=&maxPrice=&sort=
           ----------------------------------------------- */
        function renderStars(rating) {
            if (!rating) return '<span style="color:var(--gray-3)">★★★★★</span>';
            const full = Math.floor(rating);
            const empty = 5 - full;
            return '★'.repeat(full) + '<span style="color:var(--gray-3)">★</span>'.repeat(empty);
        }

        function getCardBadge(p) {
            if (p.IsSale) return `<span class="card-status-badge badge-sale">−${p.DiscountID}%</span>`;
            if (p.IsNew) return `<span class="card-status-badge badge-new">NEW</span>`;
            if (!p.IsActive) return `<span class="card-status-badge badge-soon">SOON</span>`;
            return '';
        }

        function getBestVariant(variants) {
            if (!variants || variants.length === 0) return null;

            return variants.reduce((best, v) => {
                const bestPrice = calculatePrice(best).finalPrice;
                const currPrice = calculatePrice(v).finalPrice;

                return currPrice < bestPrice ? v : best;
            });
        }

        function buildGridCard(product) {

            if (!product.VariantList || product.VariantList.length === 0) return '';

            const p = getBestVariant(product.VariantList);

            const { originalPrice, discountAmount, finalPrice } = calculatePrice(p);

            const hasDiscount = discountAmount > 0;

            const priceHtml = hasDiscount
                ? `
                    <span class="price-current">₹${finalPrice}</span>
                    <span class="price-original text-decoration-line-through ms-2">₹${originalPrice}</span>
                    <span class="price-save ms-2 text-success">Save ₹${discountAmount}</span>
                    `
                            : `<span class="price-current">₹${originalPrice}</span>`;

                        const ratingHtml = product.Rating > 0
                            ? `
                    <div class="d-flex align-items-center gap-1 mt-1">
                        <span class="stars-pc">${renderStars(product.Rating)}</span>
                        <span class="review-count">${product.Rating}</span>
                    </div>
                    `
                            : '';

                        return `
                            <div class="col-6 col-md-4 fade-up">
                                <div class="product-card h-100" onclick="openDetail(${product.ProductID})">

                                    <div class="card-img-wrap position-relative" style="height:240px">
                                        <img src="${p.ImageURL}" alt="${product.ProductName}" loading="lazy">
                                        ${getCardBadge(p)}
                                    </div>

                                    <div class="card-body-pc">
                                        <span class="card-label-pc">${product.Brand}</span>
                                        <h6 class="card-name-pc">${product.ProductName}</h6>
                                        <p class="card-caption">${product.ProductCaption}</p>

                                        ${ratingHtml}

                                        <div class="price-row mt-2">
                                            ${priceHtml}
                                        </div>
                                    </div>
                                </div>
                            </div>`;
        }

        function buildListCard(product) {

            if (!product.VariantList || product.VariantList.length === 0) return '';

            const p = getBestVariant(product.VariantList);
            const { originalPrice, discountAmount, finalPrice } = calculatePrice(p);

            const hasDiscount = discountAmount > 0;

            const priceHtml = hasDiscount
                ? `
                    <div>
                        <div class="price-current">₹${finalPrice}</div>
                        <div class="price-original text-decoration-line-through">₹${originalPrice}</div>
                        <div class="price-save text-success">Save ₹${discountAmount}</div>
                    </div>`
                            : `<div class="price-current">₹${originalPrice}</div>`;

            return `
                <div class="list-card fade-up" onclick="openDetail(${product.ProductID})">

                    <div class="list-img">
                        <img src="${p.ImageURL}" alt="${product.ProductName}">
                    </div>

                    <div class="list-body d-flex justify-content-between align-items-center">

                        <div>
                            <span class="card-label-pc">${product.Brand}</span>
                            <h6>${product.ProductName}</h6>
                            <p>${product.ProductCaption}</p>
                        </div>

                        <div class="text-end">
                            ${priceHtml}
                        </div>

                    </div>
                </div>`;
        }

        function renderProducts(products) {
            const grid = document.getElementById('productGrid');
            const list = document.getElementById('productList');
            const none = document.getElementById('noResults');

            if (!products.length) {
                grid.innerHTML = ''; list.innerHTML = '';
                none.classList.remove('d-none');
                document.getElementById('paginationWrap').classList.add('d-none');
                return;
            }
            none.classList.add('d-none');
            document.getElementById('paginationWrap').classList.remove('d-none');

            grid.innerHTML = products.map(buildGridCard).join('');
            list.innerHTML = products.map(buildListCard).join('');

            // Update counts
            document.getElementById('resultSummary').textContent = `Showing ${products.length} products`;
            document.getElementById('gridResultCount').textContent = `${products.length} Products`;

            // Trigger fade animations
            setTimeout(() => {
                document.querySelectorAll('.fade-up').forEach((el, i) => {
                    setTimeout(() => el.classList.add('visible'), i * 60);
                });
            }, 50);
        }

        function showColorOptions(variantList) {

            //const uniqueColors = [];
            //const seen = new Set();

            //variantList.forEach(v => {
            //    if (!seen.has(v.ColorCode)) {
            //        seen.add(v.ColorCode);
            //        uniqueColors.push(v);
            //    }
            //});

            //SELECTED_COLOR = uniqueColors[0]?.ColorCode;

            SELECTED_COLOR = variantList[0]?.ColorCode;

            document.getElementById('modalColors').innerHTML = variantList.map((v, i) =>
                `<div class="color-chip ${i === 0 ? 'active' : ''}" 
                  style="background:${v.ColorCode}"
                  onclick="selectColor(this, '${v.ColorCode}')">
                </div>`
            ).join('');

            // Update UI for first color
            updateVariantUI();
        }

        function openDetail(id) {

            const product = PRODUCTS.find(x => Number(x.ProductID) === Number(id));
            if (!product) return;

            CURRENT_PRODUCT = product;

            const p = getBestVariant(product.VariantList);

            const { finalPrice } = calculatePrice(p);

            document.getElementById('modalImg').src = p.ImageURL;
            document.getElementById('modalName').textContent = product.ProductName;
            document.getElementById('modalPrice').textContent = '₹' + finalPrice;
            document.getElementById('modalCaption').textContent = product.ProductCaption;

            document.getElementById('modalCategory').textContent = product.Category;
            document.getElementById('modalSubCategory').textContent = product.SubCategory;
            document.getElementById('modalBrandMeta').textContent = product.Brand;

            document.getElementById('modalDescription').textContent = product.ProductDescription;

            // Status with dot
            const statusEl = document.getElementById('modalStatus');
            const isActive = p.IsActive && p.Status === 'Active';
            statusEl.innerHTML = `<span class="status-dot ${isActive ? 'status-active' : 'status-inactive'}"></span>${p.Status}`;

            // Drop date
            document.getElementById('modalDropDate').textContent = p.DropDate ? formatDate(p.DropDate) : 'Available';

            // Sizes
            const sizes = [...new Set(product.VariantList.map(v => v.SizeName))];

            SELECTED_SIZE = sizes[0]; // default

            document.getElementById('modalSizes').innerHTML = sizes.map((s, i) =>
                `<div class="size-chip ${i === 0 ? 'active' : ''}" 
              onclick="selectSize(this, '${s}')">${s}</div>`
            ).join('');

            // Show colors for default size
            const variantsBySize = product.VariantList.filter(v => v.SizeName === SELECTED_SIZE);
            showColorOptions(variantsBySize);

            new bootstrap.Modal(document.getElementById('productDetailModal')).show();
        }

        function formatDate(dateStr) {
            if (!dateStr) return '—';
            return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        /* ---- UI Interactions ---- */
        function changeQty(delta) {
            currentQty = Math.max(1, Math.min(10, currentQty + delta));
            document.getElementById('qtyDisplay').textContent = currentQty;
        }
        function selectSize(el, size) {

            el
                .closest('.size-chips')
                .querySelectorAll('.size-chip')
                .forEach(c => c.classList.remove('active'));

            el.classList.add('active');

            SELECTED_SIZE = size;

            // filter variants for this size
            const variantsBySize = CURRENT_PRODUCT.VariantList
                .filter(v => v.SizeName === size);

            // update colors
            showColorOptions(variantsBySize);
        }

        function selectColor(el, colorCode) {

            el
                .closest('.color-chips')
                .querySelectorAll('.color-chip')
                .forEach(c => c.classList.remove('active'));

            el.classList.add('active');

            SELECTED_COLOR = colorCode;

            // update UI based on selection
            updateVariantUI();
        }

        function updateVariantUI() {

            if (!CURRENT_PRODUCT) return;

            const variant = CURRENT_PRODUCT.VariantList.find(v =>
                v.SizeName === SELECTED_SIZE &&
                v.ColorCode === SELECTED_COLOR
            );

            if (!variant) return;

            const { finalPrice } = calculatePrice(variant);

            // Update UI
            document.getElementById('modalImg').src = variant.ImageURL;
            document.getElementById('modalPrice').textContent = '₹' + finalPrice;
        }

        function toggleWish(btn) {
            const icon = btn.querySelector('i');
            const isWished = icon.classList.contains('bi-heart-fill');
            icon.classList.toggle('bi-heart', isWished);
            icon.classList.toggle('bi-heart-fill', !isWished);
            btn.style.color = isWished ? '' : '#e53935';
            btn.classList.toggle('wishlisted', !isWished);
            showToast(isWished ? 'Removed from wishlist' : 'Saved to wishlist ♥');
        }

        function wishlistToggle(btn) {
            const isWished = btn.querySelector('i').classList.contains('bi-heart-fill');
            btn.innerHTML = isWished
                ? '<i class="bi bi-heart"></i> Save to Wishlist'
                : '<i class="bi bi-heart-fill" style="color:#e53935"></i> Wishlisted';
        }

        function addToCart() {
            cartCount += currentQty;
            updateCartBadge();
            bootstrap.Modal.getInstance(document.getElementById('productDetailModal'))?.hide();
            showToast(`${currentQty} item${currentQty > 1 ? 's' : ''} added to bag 🛍️`);
        }

        function addToCartQuick(name) {
            cartCount++;
            updateCartBadge();
            showToast(`"${name.split(' ').slice(0, 2).join(' ')}" added to bag`);
        }

        function updateCartBadge() {
            document.getElementById('cartCount').textContent = cartCount;
            document.getElementById('tabBadge').textContent = cartCount;
        }

        function showToast(msg) {
            document.getElementById('toastMsg').textContent = msg;
            const toast = new bootstrap.Toast(document.getElementById('cartToast'), { delay: 2500 });
            toast.show();
        }

        /* ---- Filters + Sort ---- */
        function getFilteredProducts() {
            const activeCat = document.querySelector('.cat-pill.active')?.dataset.cat || 'all';
            const maxPrice = parseInt(document.getElementById('priceRange').value);
            const sortVal = document.getElementById('sortSelect').value;

            let filtered = PRODUCTS.filter(p => {
                const catMatch =
                    activeCat === 'all' ||
                    (activeCat === 'sale' && p.IsSale) ||
                    p.CategoryID.toLowerCase() === activeCat ||
                    p.SubCategoryID.toLowerCase() === activeCat;

                const priceMatch = p.Price <= maxPrice;

                return catMatch && priceMatch;
            });

            // clone array before sorting
            filtered = [...filtered];

            if (sortVal === 'Price: Low to High')
                filtered.sort((a, b) => a.Price - b.Price);

            else if (sortVal === 'Price: High to Low')
                filtered.sort((a, b) => b.Price - a.Price);

            else if (sortVal === 'Newest First')
                filtered.sort((a, b) => b.ProductID - a.ProductID);

            else if (sortVal === 'Top Rated')
                filtered.sort((a, b) => b.Rating - a.Rating);

            return filtered;
        }

        document.querySelectorAll('.cat-pill').forEach(pill => {
            pill.addEventListener('click', () => {
                document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
                pill.classList.add('active');
                renderProducts(getFilteredProducts());
            });
        });

        document.getElementById('sortSelect').addEventListener('change', () => renderProducts(getFilteredProducts()));
        document.getElementById('priceRange').addEventListener('change', () => renderProducts(getFilteredProducts()));

        /* ---- View Toggle ---- */
        document.getElementById('gridViewBtn').addEventListener('click', () => {
            isGridView = true;
            document.getElementById('productGrid').classList.remove('d-none');
            document.getElementById('productList').classList.add('d-none');
            document.getElementById('gridViewBtn').classList.add('active');
            document.getElementById('listViewBtn').classList.remove('active');
        });
        document.getElementById('listViewBtn').addEventListener('click', () => {
            isGridView = false;
            document.getElementById('productGrid').classList.add('d-none');
            document.getElementById('productList').classList.remove('d-none');
            document.getElementById('listViewBtn').classList.add('active');
            document.getElementById('gridViewBtn').classList.remove('active');
        });

        /* ---- Scroll fade-up ---- */
        const observer = new IntersectionObserver(entries => {
            entries.forEach((e, i) => {
                if (e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i * 55);
            });
        }, { threshold: 0.1 });

        /* ---- Filter sidebar chip clicks ---- */
        document.querySelectorAll('.size-chip').forEach(c => {
            c.addEventListener('click', () => {
                c.classList.toggle('active');
            });
        });

        /* ---- INIT — load products on page ready ---- */
        /* In MVC: replaced by $.ajax({ url:'/Product/GetProducts', success: renderProducts }) */
        document.addEventListener('DOMContentLoaded', () => {
            //renderProducts(PRODUCTS);
        });
    </script>
</body>
</html>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.js" integrity="sha512-+k1pnlgt4F1H8L7t3z95o3/KO+o78INEcXTbnoJQ/F2VqDVhWoaiVml/OEHv9HsVgxUaVW+IbiZPUJQfF/YxZw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<script>

    function renderCategoryPills(categoryList)
    {
        categoryList.forEach(item => {
            const html = `
                    <div class="cat-pill" data-cat="${item.Category}" data-id=${item.CategoryID}>

                        ${item.Category}
                    </div>
                `
            $("#categoryPills").append(html);
        })
    }

    function getAllCategories()
    {
        $.ajax({
            url: `@categoryURL`,
            data: {
                //hardcoded
                CustomerID: 1
            },
            type: 'GET',
            success: function (response) {
                //console.log("S-Response: ", response)
                renderCategoryPills(response)
            },
            error: function (response) {
                //console.log("E-Response: ", response)
            }
        })
    }

    function setActiveCategory(categoryName) {
        $('.cat-pill').removeClass('active');

        $(`.cat-pill[data-cat="${categoryName}"]`).addClass('active');
    }

    function getAllProducts()
    {
        $.ajax({
            url: `@allProductURL`,
            data: {
                //hardcoded
                CustomerID: 1
            },
            type: 'GET',
            success: function (response) {
                console.log("Products S-Response: ", response)
                PRODUCTS = response;
                renderProducts(response)
            },
            error: function (response) {
                console.log("E-Response: ", response)
            }
        })
    }

    $(document).ready(function () {

        // Fetch all categories by CustomerID and render them
        getAllCategories()

        // Set the active category on click
        $(document).on('click', '.cat-pill', function () {

            const category = $(this).data('cat');
            const categoryId = $(this).data('id');

            //console.log("Selected:", category, categoryId);
            setActiveCategory(category)
        })

        getAllProducts()

    })
</script>