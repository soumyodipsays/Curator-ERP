@using System.Configuration
@{
    ViewBag.Title = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var loginUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/Login";
    var profileUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/GetProfile";
    var sendOTPUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/SendOTP";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-5">
            <div class="card border-0 shadow-sm rounded-4 p-4">

                <div class="text-center mb-4">
                    <span class="fw-bold fs-4 text-dark">Curator.</span>
                    <p class="text-muted small mt-1 mb-0">
                        Welcome back. Sign in to continue.
                    </p>
                </div>

                <form id="loginForm">

                    <div class="mb-3">
                        <label class="form-label small fw-medium text-dark">
                            Email address
                        </label>

                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope"></i>
                            </span>

                            @Html.TextBox("Email", "", new
                            {
                                @class = "form-control border-start-0 bg-light",
                                type = "email",
                                placeholder = "you@example.com",
                                required = "required"
                            })
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between">
                            <label class="form-label small fw-medium text-dark">
                                Password
                            </label>

                            <a href="@Url.Action("ForgotPassword","User")"
                               class="small text-decoration-none"
                               style="color:#0071e3">
                                Forgot password?
                            </a>
                        </div>

                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock"></i>
                            </span>

                            @Html.Password("Password", "", new
                            {
                                @class = "form-control border-start-0 bg-light",
                                placeholder = "••••••••",
                                id = "login-pw",
                                required = "required"
                            })

                            <button type="button"
                                    class="btn btn-light border border-start-0"
                                    onclick="togglePw('login-pw', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox"
                               class="form-check-input"
                               id="remember">

                        <label class="form-check-label small text-muted"
                               for="remember">
                            Keep me signed in
                        </label>
                    </div>

                    <div class="d-grid">
                        <button type="submit"
                                class="btn btn-dark rounded-pill py-2 fw-medium">
                            Sign In
                        </button>
                    </div>

                </form>

                <p class="text-center text-muted small mt-4 mb-0">
                    Don't have an account?

                    <a href="@Url.Action("Register","User")"
                       class="text-decoration-none fw-medium"
                       style="color:#0071e3">
                        Create one
                    </a>
                </p>

            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<script>

$(document).ready(function () {

    // already logged in
    const token =
        localStorage.getItem("token") ||
        sessionStorage.getItem("token");

    if (token) {
        validateExistingToken(token);
    }

});


$('#loginForm').on('submit', function (e) {

    e.preventDefault();

    var data = {
        Email: $('input[name=Email]').val(),
        Password: $('input[name=Password]').val()
    };

    $.ajax({
        url: '@loginUrl',
        type: 'POST',
        contentType: 'application/json',
        dataType: 'json',
        data: JSON.stringify(data),

        success: function (res) {

            if (res.success) {

                saveToken(res.accessToken);

                window.location.href = '@Url.Action("Dashboard","Home")';
            }
            else {

                if (res.message &&
                    res.message.toLowerCase().includes("not verified")) {

                    var email =
                        $('input[name=Email]').val();

                    sessionStorage.setItem(
                        "pendingEmail",
                        email
                    );

                    resendOtp(email);
                }
                else {
                    alert(res.message || "Login failed");
                }
            }
        },

        error: function () {
            alert("Login failed");
        }
    });

});


function saveToken(token) {

    if ($('#remember').is(':checked')) {
        localStorage.setItem("token", token);
    }
    else {
        sessionStorage.setItem("token", token);
    }
}


function validateExistingToken(token) {

    $.ajax({
        url: '@profileUrl',
        type: 'POST',

        headers: {
            Authorization: 'Bearer ' + token
        },

        success: function (res) {

            if (res.success) {
                window.location.href = '@Url.Action("Dashboard","Home")';
            }
            else {
                logoutUser();
            }
        },

        error: function () {
            logoutUser();
        }
    });
}


function resendOtp(email) {

    $.ajax({
        url: '@sendOTPUrl',
        type: 'POST',
        data: { email: email },

        success: function () {
            alert("Your account is not verified. OTP sent.");
            window.location.href =
                '@Url.Action("VerifyOTP","User")';
        },

        error: function () {
            alert("Failed to send OTP.");
        }
    });
}


function logoutUser() {
    localStorage.removeItem("token");
    sessionStorage.removeItem("token");
    localStorage.removeItem("user");
    sessionStorage.removeItem("user");
}


function togglePw(id, btn) {

    var input = document.getElementById(id);
    var icon = btn.querySelector("i");

    if (input.type === "password") {
        input.type = "text";
        icon.className = "bi bi-eye-slash";
    }
    else {
        input.type = "password";
        icon.className = "bi bi-eye";
    }
}

</script>