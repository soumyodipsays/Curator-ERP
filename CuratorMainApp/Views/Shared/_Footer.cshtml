@*<%-- Views/Shared/_Footer.cshtml --%>*@

<footer class="apple-footer">
    <div class="container-xl px-4">
        <div class="row g-5">

            @*<%-- Brand column --%>*@
            <div class="col-12 col-md-4">
                <h4 style="font-size:1.1rem; font-weight:700; letter-spacing:-0.02em; margin-bottom:10px">
                    Curator.
                </h4>
                <p class="footer-link" style="line-height:1.6; max-width:260px">
                    Defining modern elegance through a meticulously edited selection
                    of international designers.
                </p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="nav-icon-btn" style="background:var(--gray-2)" aria-label="Instagram">
                        <i class="bi bi-instagram"></i>
                    </a>
                    <a href="#" class="nav-icon-btn" style="background:var(--gray-2)" aria-label="X / Twitter">
                        <i class="bi bi-twitter-x"></i>
                    </a>
                    <a href="#" class="nav-icon-btn" style="background:var(--gray-2)" aria-label="TikTok">
                        <i class="bi bi-tiktok"></i>
                    </a>
                </div>
            </div>

            @*<%-- Customer --%>*@
            <div class="col-6 col-md-2 offset-md-2">
                <h6 class="footer-col-title">Customer</h6>
                <a href="@Url.Action("Shipping", "Info")" class="footer-link">Shipping</a>
                <a href="@Url.Action("Returns",  "Info")" class="footer-link">Returns</a>
                <a href="@Url.Action("Contact",  "Home")" class="footer-link">Contact</a>
                <a href="@Url.Action("Faq",      "Info")" class="footer-link">FAQ</a>
            </div>

            @*<%-- Company --%>*@
            <div class="col-6 col-md-2">
                <h6 class="footer-col-title">Company</h6>
                <a href="@Url.Action("About",   "Home")" class="footer-link">About</a>
                <a href="@Url.Action("Journal", "Home")" class="footer-link">Journal</a>
                <a href="@Url.Action("Careers", "Home")" class="footer-link">Careers</a>
                <a href="@Url.Action("Press",   "Home")" class="footer-link">Press</a>
            </div>

            @*<%-- Legal --%>*@
            <div class="col-6 col-md-2">
                <h6 class="footer-col-title">Legal</h6>
                <a href="@Url.Action("Privacy", "Info")" class="footer-link">Privacy</a>
                <a href="@Url.Action("Terms",   "Info")" class="footer-link">Terms</a>
                <a href="@Url.Action("Cookies", "Info")" class="footer-link">Cookies</a>
            </div>

        </div>

        @*<%-- Bottom bar --%>*@
        <div class="footer-legal d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <span>© @DateTime.Now.Year Curator. All rights reserved.</span>
            <div class="d-flex gap-3">
                <img src="https://cdn.jsdelivr.net/npm/payment-icons@1.1.0/min/flat/visa.svg"
                     alt="Visa" height="20" />
                <img src="https://cdn.jsdelivr.net/npm/payment-icons@1.1.0/min/flat/mastercard.svg"
                     alt="Mastercard" height="20" />
                <img src="https://cdn.jsdelivr.net/npm/payment-icons@1.1.0/min/flat/paypal.svg"
                     alt="PayPal" height="20" />
                <img src="https://cdn.jsdelivr.net/npm/payment-icons@1.1.0/min/flat/amex.svg"
                     alt="Amex" height="20" />
            </div>
        </div>
    </div>
</footer>
