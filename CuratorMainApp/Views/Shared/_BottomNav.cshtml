@*<%-- Views/Shared/_BottomNav.cshtml --%>*@

<div class="ios-tab-bar">
    <div class="d-flex justify-content-around align-items-center px-2">

        <a href="@Url.Action("Index", "Home")"
           class="tab-item @(ViewContext.RouteData.Values["controller"].ToString() == "Home" ? "active" : "")">
            <i class="bi bi-house"></i>
            <span>Home</span>
        </a>

        <a href="@Url.Action("Search", "Products")" class="tab-item">
            <i class="bi bi-search"></i>
            <span>Search</span>
        </a>

        <a href="@Url.Action("Index", "Cart")"
           class="tab-item position-relative @(ViewContext.RouteData.Values["controller"].ToString() == "Cart" ? "active" : "")">
            <i class="bi bi-bag"></i>
            @if (ViewBag.CartCount != null && (int)ViewBag.CartCount > 0)
            {
                <span class="tab-badge">@ViewBag.CartCount</span>
            }
            <span>Bag</span>
        </a>

        <a href="@Url.Action("Index", "Wishlist")"
           class="tab-item @(ViewContext.RouteData.Values["controller"].ToString() == "Wishlist" ? "active" : "")">
            <i class="bi bi-heart"></i>
            <span>Saved</span>
        </a>

        <a href="@Url.Action("Index", "Account")"
           class="tab-item @(ViewContext.RouteData.Values["controller"].ToString() == "Account" ? "active" : "")">
            <i class="bi bi-person"></i>
            <span>Profile</span>
        </a>

    </div>
</div>
