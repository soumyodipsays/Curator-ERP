@*<%-- Views/Shared/_TopRated.cshtml --%>
<%-- Model: IEnumerable<Curator.Models.RatedProductViewModel> --%>*@
@model IEnumerable<Curator.Models.RatedProductViewModel>

<section class="apple-section apple-section-gray">
    <div class="container-xl px-4">

        <div class="text-center mb-5 fade-up">
            <span class="section-eyebrow">Most Loved</span>
            <h2 class="section-title">Community Favorites</h2>
            <p class="section-sub">Highest rated pieces from the last 30 days</p>
        </div>

        <div class="row g-4">
            @foreach (var p in Model)
            {
                <div class="col-6 col-lg-3 fade-up">
                    <div class="apple-card h-100">
                        <div class="card-img-wrap position-relative"
                             style="height:220px; background:#f5f5f7;
                                    display:flex; align-items:center; justify-content:center">
                            <img src="@p.ImageUrl"
                                 alt="@p.Name"
                                 style="object-fit:contain!important; padding:16px" />
                            <button class="card-wish-btn"
                                    data-product-id="@p.Id"
                                    title="Add to wishlist">
                                <i class="bi bi-heart"></i>
                            </button>
                        </div>
                        <div class="card-body-apple">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="card-name mb-1">@p.Name</h6>
                                    <div class="d-flex align-items-center gap-1">
                                        <span class="stars">@p.StarsHtml</span>
                                        <span class="rating-count">
                                            @p.Rating.ToString("F1") (@p.ReviewCount)
                                        </span>
                                    </div>
                                </div>
                                <span class="card-price-highlight">
                                    @p.Price.ToString("C0")
                                </span>
                            </div>
                        </div>
                        <div class="quick-add">
                            <button class="quick-add-btn" data-product-id="@p.Id">Add to Bag</button>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div>
</section>
