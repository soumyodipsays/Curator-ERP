@*<%-- Views/Shared/_FeaturedProducts.cshtml --%>
<%-- Model: IList<Curator.Models.ProductCardViewModel>  (expects at least 3 items) --%>*@
@model IList<Curator.Models.ProductCardViewModel>

<section class="apple-section">
    <div class="container-xl px-4">

        <div class="d-flex justify-content-between align-items-end mb-5 fade-up">
            <div>
                <span class="section-eyebrow">Curation 01</span>
                <h2 class="section-title">Featured Items</h2>
            </div>
            <a href="@Url.Action("Index", "Products")"
               class="btn-apple-outline d-none d-md-inline-flex">
                View All <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="row g-4">

            @*<%-- Large hero card — first product --%>*@
            @if (Model.Count > 0)
            {
                var p = Model[0];
                <div class="col-10 col-md-8 fade-up">
                    <div class="apple-card h-100">
                        <div class="card-img-wrap position-relative" style="height:620px">
                            <img src="@p.ImageUrl" alt="@p.Name" />
                            <button class="card-wish-btn"
                                    data-product-id="@p.Id"
                                    title="Add to wishlist">
                                <i class="bi bi-heart"></i>
                            </button>
                        </div>
                        <div class="card-body-apple">
                            <span class="card-label">@p.Label</span>
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="card-name mb-0">@p.Name</h5>
                                <span class="card-price-highlight">@p.Price.ToString("C0")</span>
                            </div>
                        </div>
                        <div class="quick-add">
                            <button class="quick-add-btn" data-product-id="@p.Id">Add to Bag</button>
                            <button class="quick-bag-btn" data-product-id="@p.Id" title="Save">
                                <i class="bi bi-bag-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }

            @*<%-- Two stacked small cards --%>*@
            <div class="col-12 col-md-4 d-flex flex-column gap-4">
                @for (int i = 1; i <= 2 && i < Model.Count; i++)
                {
                    var p = Model[i];
                    <div class="apple-card flex-fill fade-up" style="animation-delay:@(i * 0.1)s">
                        <div class="card-img-wrap position-relative" style="height:248px">
                            <img src="@p.ImageUrl" alt="@p.Name" />
                            <button class="card-wish-btn"
                                    data-product-id="@p.Id"
                                    title="Add to wishlist">
                                <i class="bi bi-heart"></i>
                            </button>
                        </div>
                        <div class="card-body-apple">
                            <span class="card-label">@p.Label</span>
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="card-name mb-0">@p.Name</h6>
                                <span class="card-price-highlight">@p.Price.ToString("C0")</span>
                            </div>
                        </div>
                        <div class="quick-add">
                            <button class="quick-add-btn" data-product-id="@p.Id">Add to Bag</button>
                            <button class="quick-bag-btn" data-product-id="@p.Id">
                                <i class="bi bi-bag-plus"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</section>
