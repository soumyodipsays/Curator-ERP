<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — Curator.</title>

    @*<%-- Bootstrap & Icons --%>*@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;600;700&display=swap" rel="stylesheet" />

    @*<%-- Site CSS --%>*@
    @Styles.Render("~/Content/curator.css")

    @RenderSection("Styles", required: false)
</head>
<body>

    @*<%-- ===== NAVBAR ===== --%>*@
    @Html.Partial("_Navbar")

    @*<%-- ===== MAIN CONTENT ===== --%>*@
    <main style="padding-top:56px">
        @RenderBody()
    </main>

    @*<%-- ===== FOOTER ===== --%>*@
    @Html.Partial("_Footer")

    @*<%-- ===== MOBILE BOTTOM NAV ===== --%>*@
    @Html.Partial("_BottomNav")

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-4">

        <div id="appToast"
             class="toast border-0 shadow"
             role="alert"
             aria-live="assertive"
             aria-atomic="true"
             style="
            width:360px;
            border-radius:22px;
            background:#ffffff;
            overflow:hidden;
            box-shadow:
                0 10px 35px rgba(15,23,42,0.12);
         ">

            <div class="d-flex align-items-start p-3">

                <!-- Icon -->
                <div style="
                width:44px;
                height:44px;
                border-radius:14px;
                background:#eef4ff;
                display:flex;
                align-items:center;
                justify-content:center;
                flex-shrink:0;
                margin-right:14px;
            ">

                    <i id="toastIcon"
                       class="bi bi-check-circle-fill"
                       style="
                        font-size:1.15rem;
                        color:#2563eb;
                   ">
                    </i>

                </div>

                <!-- Content -->
                <div class="flex-grow-1">

                    <div style="
                    font-size:.95rem;
                    font-weight:700;
                    color:#111827;
                    margin-bottom:2px;
                ">
                        Notification
                    </div>

                    <div id="toastMsg"
                         style="
                        font-size:.88rem;
                        color:#6b7280;
                        line-height:1.5;
                     ">

                        Changes saved successfully.

                    </div>

                </div>

                <!-- Close -->
                <button type="button"
                        class="btn-close ms-3 mt-1"
                        data-bs-dismiss="toast">
                </button>

            </div>

            <!-- Bottom Accent -->
            <div style="
            height:4px;
            background:linear-gradient(
                90deg,
                #2563eb,
                #60a5fa
            );
        "></div>

        </div>

    </div>

    @*<%-- Scripts --%>*@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @using System.Configuration

    <script>
        window.AppConfig = {
            authBaseUrl: '@ConfigurationManager.AppSettings["AuthServiceBaseUrl"]',
            loginUrl: '@ConfigurationManager.AppSettings["AuthServiceBaseUrl"]/User/Login',
            profileUrl: '@ConfigurationManager.AppSettings["AuthServiceBaseUrl"]/User/GetProfile',

            mvcLoginPage: '@Url.Action("Login", "User")'
        };
    </script>

    <script src="~/Scripts/auth.js"></script>
    <script src="~/Scripts/curator-profile.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>