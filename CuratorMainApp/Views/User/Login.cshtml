@using System.Configuration
@{
    ViewBag.Title = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var loginUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/Login";
    var profileUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/GetProfile";
    var sendOTPUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/SendOTP";
    var productURL = ConfigurationManager.AppSettings["ProductServiceBaseUrl"];

}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-5">
            <div class="card border-0 shadow-sm rounded-4 p-4">

                <div class="text-center mb-4">
                    <span class="fw-bold fs-4 text-dark">Curator.</span>
                    <p class="text-muted small mt-1 mb-0">
                        Welcome back. Sign in to continue.
                    </p>
                </div>

                <!-- GLOBAL MESSAGE -->
                <div id="msgBox" class="alert d-none"></div>

                <form id="loginForm">

                    <div class="mb-3">
                        <label class="form-label small fw-medium text-dark">
                            Email address
                        </label>

                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope"></i>
                            </span>

                            @Html.TextBox("Email", "", new
                            {
                                @class = "form-control border-start-0 bg-light",
                                type = "email",
                                placeholder = "you@example.com",
                                required = "required"
                            })
                        </div>

                        <small id="emailError" class="text-danger"></small>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between">
                            <label class="form-label small fw-medium text-dark">
                                Password
                            </label>

                            <a href="@Url.Action("ForgotPassword","User")"
                               class="small text-decoration-none"
                               style="color:#0071e3">
                                Forgot password?
                            </a>
                        </div>

                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock"></i>
                            </span>

                            @Html.Password("Password", "", new
                            {
                                @class = "form-control border-start-0 bg-light",
                                placeholder = "••••••••",
                                id = "login-pw",
                                required = "required"
                            })

                            <button type="button"
                                    class="btn btn-light border border-start-0"
                                    onclick="togglePw('login-pw', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>

                        <small id="passwordError" class="text-danger"></small>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox"
                               class="form-check-input"
                               id="remember">

                        <label class="form-check-label small text-muted"
                               for="remember">
                            Keep me signed in
                        </label>
                    </div>

                    <div class="d-grid">
                        <button type="submit"
                                id="btnLogin"
                                class="btn btn-dark rounded-pill py-2 fw-medium">
                            Sign In
                        </button>
                    </div>

                </form>

                <p class="text-center text-muted small mt-4 mb-0">
                    Don't have an account?

                    <a href="@Url.Action("Register","User")"
                       class="text-decoration-none fw-medium"
                       style="color:#0071e3">
                        Create one
                    </a>
                </p>

            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="~/Scripts/auth.js"></script>

<script>

    $(document).ready(function () {

        if (Auth.getToken()) {
            Auth.validate(function () {
                window.location.href = '@Url.Action("Index","Home")';
            });
        }

    });

    $('#loginForm').on('submit', function (e) {

        e.preventDefault();

        clearErrors();

        var email = $('input[name=Email]').val().trim();
        var password = $('input[name=Password]').val().trim();

        var isValid = true;

        if (email === "") {
            $('#emailError').text("Email is required.");
            isValid = false;
        }

        if (password === "") {
            $('#passwordError').text("Password is required.");
            isValid = false;
        }

        if (!isValid) return;

        $('#btnLogin').prop('disabled', true).text('Signing In...');

        $.ajax({
            url: '@loginUrl',
            type: 'POST',
            contentType: 'application/json',
            dataType: 'json',
            data: JSON.stringify({
                Email: email,
                Password: password
            }),

            success: function (res) {
                console.log("Login Response:", res);

                if (res.success) {

                    showMessage(
                        "Login successful.",
                        "success"
                    );

                    Auth.login(
                        res.accessToken,
                        $('#remember').is(':checked'),
                        res.user.userID
                    );

                    Auth.validate(function () {
                        getCartCount(res.user.userID);
                        setTimeout(function () {

                            window.location.href =
                                '@Url.Action("Index","Home")';

                        }, 1000);

                    });
                }
                else {

                    let errorMessage = "Login failed.";

                    // Handle array validation messages
                    if (Array.isArray(res.message)) {

                        errorMessage = res.message.join("<br>");

                    }
                    // Handle normal string messages
                    else if (typeof res.message === "string") {

                        errorMessage = res.message;

                        if (
                            res.message.toLowerCase()
                                .includes("not verified")
                        ) {

                            sessionStorage.setItem(
                                "pendingEmail",
                                email
                            );

                            resendOtp(email);
                            return;
                        }
                    }

                    showMessage(errorMessage, "danger");
                }

                $('#btnLogin')
                    .prop('disabled', false)
                    .text('Sign In');
            },

            error: function (xhr) {

                let msg = "Login failed.";

                if (xhr.responseJSON && xhr.responseJSON.message) {
                    msg = xhr.responseJSON.message;
                }

                showMessage(msg, "danger");

                $('#btnLogin').prop('disabled', false).text('Sign In');
            }

        });

    });

    function resendOtp(email) {

        $.ajax({
            url: '@sendOTPUrl',
            type: 'POST',
            data: { email: email },

            success: function () {

                showMessage("OTP sent successfully.", "success");

                setTimeout(function () {
                    window.location.href =
                        '@Url.Action("VerifyOTP","User")';
                }, 1000);
            },

            error: function () {
                showMessage("Failed to send OTP.", "danger");
            }
        });

    }

    function showMessage(message, type) {

        $('#msgBox')
            .removeClass(
                'd-none alert-success alert-danger alert-warning'
            )
            .addClass('alert-' + type)
            .html(message)
            .hide()
            .fadeIn();

        // Auto hide success messages
        if (type === "success") {

            setTimeout(function () {

                $('#msgBox').fadeOut();

            }, 3000);
        }
    }

    function clearErrors() {
        $('#emailError').text('');
        $('#passwordError').text('');
        $('#msgBox').addClass('d-none').text('');
    }
    function getCartCount(userId) {
        $.ajax({
            url: '@productURL/Cart/GetCartDetails', // Make sure this matches your C# variable name (productUrl or productURL)
            type: 'GET',
            data: {
                UserID: userId
            },
            success: function (response) {
                console.log("Cart details fetched on login: ", response);

                // 1. Save the cart items so the Home page Navbar can read them instantly
                sessionStorage.setItem('CHECKOUT_CART_STATE', (response.length || 0));

                // 2. NOW redirect the user smoothly!
                window.location.href = '@Url.Action("Index","Home")';
            },
            error: function (xhr, status, error) {
                console.error("Failed to fetch cart: ", error);

                // Failsafe: Even if the cart fails, still let them go to the Home page
                window.location.href = '@Url.Action("Index","Home")';
            }
        });
    }

    function togglePw(id, btn) {

        var input = document.getElementById(id);
        var icon = btn.querySelector("i");

        if (input.type === "password") {
            input.type = "text";
            icon.className = "bi bi-eye-slash";
        } else {
            input.type = "password";
            icon.className = "bi bi-eye";
        }
    }

</script>