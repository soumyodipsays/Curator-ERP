@model Curator.Models.HomeViewModel
@using System.Configuration;
@{
    var productURL = ConfigurationManager.AppSettings["ProductServiceBaseUrl"];
    var homePageProductURL = productURL + "/HomePageApi/GetHomePageDetails";
    ViewBag.Title = "Home Page";
    ViewBag.Title = "Home"; // Note: You have ViewBag.Title twice here, you can remove one!
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* ===== HERO ===== *@
@Html.Partial("_Hero", Model.Hero)

@* ===== BRAND MARQUEE ===== *@
@Html.Partial("_BrandStrip", Model.Brands)

@*===== CATEGORY PILLS =====
    @Html.Partial("_CategoryPills", Model.CategoryPills)
*@

@* ===== FEATURED PRODUCTS ===== *@
@Html.Partial("_FeaturedProducts")

@* ===== FLASH SALE ===== *@
@Html.Partial("_FlashSale", Model.FlashSale)

@* ===== TOP RATED ===== *@
@Html.Partial("_TopRated", Model.TopRatedProducts)

@* ===== NEWSLETTER ===== *@
@Html.Partial("_Newsletter")

@*@Html.Partial("_SearchOverlay")*@

@section scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/curator.js"></script>
    <script src="~/Scripts/search.js"></script>

    <script>
        
        function getAllDetails() {
            $.ajax({
                url: '@homePageProductURL',
                data: {
                    CustomerID: 1
                },
                type: 'GET',
                success: function (response) {
                    console.log(response);

                    @* ===== For _BrandStrip ===== *@
                    const brands = response.Brands;
                    const featuredProducts = response.FeaturedProducts;
                    const flashSaleProducts = response.FlashSaleProducts;
                    renderBrands(brands)
                    renderFeaturedProducts(featuredProducts)
                    renderFlashSaleProducts(flashSaleProducts)
                },
                error: function (response) {
                    console.log("E-Response: ", response);
                }
            });
        }

        $(document).ready(function () {
            getAllDetails();
        });
    </script>
}