@* Views/Shared/_AddressSelection.cshtml *@
@using System.Configuration
@{
        var authURL = ConfigurationManager.AppSettings["AuthServiceBaseUrl"];
}

<div id="addressContainer"></div>

<button class="add-address-btn mt-2" id="addAddrBtn">
    <i class="bi bi-plus-circle" style="font-size:1.1rem"></i>
    Add a new address
</button>

<div id="newAddressForm" style="display:none; margin-top:20px">
    <div class="apple-divider"></div>
    <div class="form-section-title">New Delivery Address</div>

    <div class="row g-3">

        <div class="col-12">
            <label class="apple-label">Address Line 1 *</label>
            <input class="apple-input" type="text" id="newAddr1" />
        </div>

        <div class="col-12">
            <label class="apple-label">Address Line 2</label>
            <input class="apple-input" type="text" id="newAddr2" />
        </div>

        <div class="col-12 col-md-6">
            <label class="apple-label">City *</label>
            <input class="apple-input" type="text" id="newCity" />
        </div>

        <div class="col-12 col-md-6">
            <label class="apple-label">PIN Code *</label>
            <input class="apple-input" type="text" id="newPin" maxlength="10" />
        </div>

        <div class="col-12 col-md-6">
            <label class="apple-label">State *</label>
            <select class="apple-select" id="newState"></select>
        </div>

        <div class="col-12">
            <label class="apple-checkbox">
                <input type="checkbox"
                       id="m-default" />
                <span>
                    Set as default address
                </span>
            </label>

        </div>

        <div class="col-12">
            <button class="btn-apple-blue" id="saveAddressBtn">
                Save Address
            </button>
        </div>

    </div>
</div>

<script>

    function loadStatesForNewAddress() {
        

        const stateURL =
            "@authURL" + "/User/GetStates";

        $.ajax({

            url: stateURL,
            type: "GET",

            success: function (response) {

                if (!response.success) {
                    return;
                }

                const $state =
                    $("#newState");

                $state.empty();

                $state.append(`
                    <option value="">
                        Select State
                    </option>
                `);

                response.data.forEach(state => {

                    $state.append(`
                        <option value="${state.StateID}">
                            ${state.State}
                        </option>
                    `);

                });

            },

            error: function (response) {

                showToast("Failed to load states");
            }
        });
    }
    function saveAddress() {

        const userid = Auth.currentUser().userId;

        const payload = {
            userID: userid,
            address1: $("#newAddr1").val(),
            address2: $("#newAddr2").val(),
            city: $("#newCity").val(),
            pinCode: $("#newPin").val(),
            stateID: $("#newState").val(),
            isDefault: $("#m-default").is(":checked")
        };

        $.ajax({
            url: "@authURL/User/AddOrEditUserAddress",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function (response) {
                alert("Address saved!");
                $("#newAddressForm").hide();
                loadAddresses();
            },
            error: function (response) {
                alert("Failed to save address");
            }
        });
    }

    function renderAddresses(addresses) {

        let html = "";

        if (!addresses || addresses.length === 0) {
            html = `
                <div class="text-center py-4" style="color:var(--gray-4)">
                    <i class="bi bi-geo-alt" style="font-size:2rem"></i>
                    <p class="mt-2 mb-0">No saved addresses. Add one below.</p>
                </div>`;
        }
        else {
            addresses.forEach(addr => {

                html += `
                <div class="address-card ${addr.IsDefault ? "selected" : ""}"
                     data-address-id="${addr.AddressID}"
                     onclick="selectAddress(this)">

                    <div class="check-icon">
                        <i class="bi bi-check"></i>
                    </div>

                    <div class="addr-label">${addr.locationType || ""}</div>

                    <div class="addr-line">
                        ${addr.Address1}
                    </div>

                    ${addr.Address2
                        ? `<div class="addr-line">${addr.Address2}</div>`
                        : ""
                    }

                    <div class="addr-pin">
                        ${addr.City}, ${addr.State} — ${addr.PinCode}
                    </div>

                    ${addr.IsDefault
                        ? `<span class="addr-tag">Default</span>`
                        : ""
                    }

                </div>`;
            });
        }

        $("#addressContainer").html(html);
    }

    function loadAddresses() {
        $.ajax({
            url: "@authURL/User/GetAllAddress",
            type: "GET",
            data: {
                UserID: sessionStorage.getItem("userId") || Auth.currentUser().userId
            },
            success: function (res) {
                renderAddresses(res.data);
            },
            error: function () {
                console.error("Failed to load addresses");
            }
        });
    }


    $(document).ready(function () {

        loadAddresses();
        loadStatesForNewAddress();
        
        // toggle form
        $("#addAddrBtn").on("click", function () {
            $("#newAddressForm").toggle();
        });

        // save address
        $("#saveAddressBtn").on("click", function () {
            saveAddress();
        });

    });
</script>