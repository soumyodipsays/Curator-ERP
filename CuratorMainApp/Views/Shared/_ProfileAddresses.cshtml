<div class="apple-card fade-up" id="addressSection">

    <div class="apple-card-inner">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-1">

            <div>
                <span class="section-eyebrow">Saved Addresses</span>
                <h2 class="section-title-sm">Delivery Locations</h2>
            </div>

            <button class="btn-profile-blue-sm" onclick="openAddressModal()">
                <i class="bi bi-plus-lg"></i> Add Address
            </button>

        </div>

        <p class="section-sub-sm mb-4">
            Manage your delivery addresses.
        </p>

        <!-- Dynamic List -->
        <div id="addressList"></div>

        <!-- Empty State -->
        <div id="noAddressMsg"
             style="display:none;text-align:center;padding:32px 0">

            <i class="bi bi-geo-alt" style="font-size:2.5rem;color:var(--gray-3)"></i>

            <p style="color:var(--gray-4);margin-top:8px;margin-bottom:0">
                No addresses saved yet.
            </p>

        </div>

    </div>
</div>


@* =========================
       ADDRESS MODAL
    ========================= *@

<div class="modal fade" id="addressModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content addr-modal-content">

            <div class="addr-modal-body">

                <!-- HEADER -->
                <div class="addr-modal-header">

                    <h5 class="addr-modal-title">
                        Add New Address
                    </h5>

                    <button type="button"
                            class="nav-icon-btn"
                            data-bs-dismiss="modal">

                        <i class="bi bi-x-lg"></i>

                    </button>

                </div>

                <!-- HIDDEN -->
                <input type="hidden"
                       id="modalAddressId"
                       value="0" />

                <div class="row g-3">

                    <!-- ADDRESS 1 -->
                    <div class="col-12">

                        <label class="apple-label">
                            Address Line 1 *
                        </label>

                        <input class="apple-input"
                               id="m-addr1"
                               type="text"
                               maxlength="100"
                               placeholder="House no, street, locality" />

                        <span class="form-error"
                              id="merr-addr1">

                            Please enter address line 1

                        </span>

                    </div>

                    <!-- ADDRESS 2 -->
                    <div class="col-12">

                        <label class="apple-label">
                            Address Line 2
                        </label>

                        <input class="apple-input"
                               id="m-addr2"
                               type="text"
                               maxlength="100"
                               placeholder="Apartment, landmark (optional)" />

                    </div>

                    <!-- CITY -->
                    <div class="col-12 col-md-6">

                        <label class="apple-label">
                            City *
                        </label>

                        <input class="apple-input"
                               id="m-city"
                               type="text"
                               maxlength="50"
                               placeholder="Enter city" />

                        <span class="form-error"
                              id="merr-city">

                            Please enter city

                        </span>

                    </div>

                    <!-- PIN -->
                    <div class="col-12 col-md-6">

                        <label class="apple-label">
                            PIN Code *
                        </label>

                        <input class="apple-input"
                               id="m-pin"
                               type="text"
                               maxlength="6"
                               placeholder="6-digit PIN"
                               oninput="this.value=this.value.replace(/\D/g,'')" />

                        <span class="form-error"
                              id="merr-pin">

                            Enter valid PIN

                        </span>

                    </div>

                    <!-- STATE -->
                    <div class="col-12">

                        <label class="apple-label">
                            State *
                        </label>

                        <select class="apple-select"
                                id="m-state">

                            @*<option value="">Select State</option>*@
                            @*<option value="1">West Bengal</option>
                            <option value="2">Maharashtra</option>
                            <option value="3">Delhi</option>*@

                        </select>

                        <span class="form-error"
                              id="merr-state">

                            Please select state

                        </span>

                    </div>

                    <!-- DEFAULT -->
                    <div class="col-12">

                        <label class="apple-checkbox">

                            <input type="checkbox"
                                   id="m-default" />

                            <span>
                                Set as default address
                            </span>

                        </label>

                    </div>

                </div>

                <div class="mt-4">

                    <button class="btn-apple-blue w-100"
                            id="addressSaveBtn"
                            onclick="submitAddressModal()">

                        <i class="bi bi-check-lg"></i>

                        <span id="addressSaveBtnText">
                            Save Address
                        </span>

                    </button>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

function renderAddress(addressList) {

    const $list = $("#addressList");
    $list.empty();

    if (!addressList || addressList.length === 0) {
        $("#noAddressMsg").show();
        return;
    }

    $("#noAddressMsg").hide();

    addressList.forEach(addr => {

        // ---------- NORMALIZE DATA ----------
        let address1 = addr.Address1 || "";
        let address2 = addr.Address2 || "";
        let city = addr.City || "";
        let state = addr.StateName || addr.State || "";
        let pin = addr.PinCode || "";

        // If backend dumped everything into Address1, try splitting it
        if ((!city || !pin) && address1.includes("\n")) {

            const parts = address1
                .split(/\r?\n/)
                .map(x => x.trim())
                .filter(Boolean);

            address1 = parts[0] || address1;
            address2 = address2 || parts[1] || "";
            city = city || (parts[2] || "");
        }

        // Extract icon/type
        let icon = "📍";
        if (addr.Location === "Home") icon = "🏠";
        else if (addr.Location === "Office") icon = "🏢";

        const html = `
            <div class="addr-profile-card ${addr.IsDefault ? "addr-default" : ""}"
                 id="addrCard-${addr.AddressID}">

                <div class="d-flex justify-content-between align-items-start mb-3">

                    <div class="d-flex align-items-center gap-2">

                        <span class="addr-type-icon">${icon}</span>

                        <span class="addr-type-label">
                            ${addr.Location || "Other"}
                        </span>

                        ${addr.IsDefault ? `<span class="addr-default-badge">Default</span>` : ""}

                    </div>

                    <div class="addr-action-row">

                        <button class="addr-icon-btn edit-address-btn"
                                data-address='${JSON.stringify(addr)}'>

                            <i class="bi bi-pencil"></i>

                        </button>

                        <button class="addr-icon-btn addr-icon-delete"
                                onclick="deleteAddress(${addr.AddressID})">

                            <i class="bi bi-trash3"></i>

                        </button>

                    </div>

                </div>

                <div class="addr-line-main">${address1}</div>

                ${address2
                ? `<div class="addr-line-sub">${address2}</div>`
                : ""
            }

                <div class="addr-line-city">
                    ${city ? city + "," : ""} ${state || ""} ${pin ? "— " + pin : ""}
                </div>

            </div>
        `;

        $list.append(html);
    });
}

</script>