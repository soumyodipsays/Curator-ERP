@using System.Configuration
@{
    ViewBag.Title = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var loginUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/Login";
    var registerUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/Register";
    var profileUrl = ConfigurationManager.AppSettings["AuthServiceBaseUrl"] + "/User/GetProfile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-5">
            <div class="card border-0 shadow-sm rounded-4 p-4">

                <div class="text-center mb-4">
                    <span class="fw-bold fs-4 text-dark">Curator.</span>
                    <p class="text-muted small mt-1 mb-0">Welcome back. Sign in to continue.</p>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <a href="/Account/GoogleLogin"
                       class="btn btn-outline-secondary d-flex align-items-center justify-content-center gap-2 rounded-pill py-2">
                        <img src="https://img.icons8.com/color/48/google-logo.png"
                             alt="Google"
                             style="width:20px; height:20px;" />
                        Sign in with Google
                    </a>
                    @*<a href="/Account/AppleLogin" class="btn btn-dark d-flex align-items-center justify-content-center gap-2 rounded-pill py-2">
                            <i class="bi bi-apple"></i> Continue with Apple
                        </a>*@
                </div>

                <div class="d-flex align-items-center gap-2 my-3">
                    <hr class="flex-grow-1 m-0">
                    <span class="text-muted small">or</span>
                    <hr class="flex-grow-1 m-0">
                </div>

                <form id="loginForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label small fw-medium text-dark">Email address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted">
                                <i class="bi bi-envelope"></i>
                            </span>
                            @Html.TextBox("Email", "", new
                            {
                                @class = "form-control border-start-0 bg-light",
                              @placeholder = "you@example.com",
                                @type = "email"
                            })
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between">
                            <label class="form-label small fw-medium text-dark">Password</label>
                            <a href="@Url.Action("ForgotPassword","User")"
                               class="small text-decoration-none" style="color:#0071e3">Forgot password?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted">
                                <i class="bi bi-lock"></i>
                            </span>
                            @Html.Password("Password", "", new
                            {
                                @class = "form-control border-start-0 bg-light",
                              @placeholder = "••••••••",
                                id = "login-pw"
                            })
                            <button class="btn btn-light border border-start-0" type="button"
                                    onclick="togglePw('login-pw', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="remember" name="RememberMe">
                        <label class="form-check-label small text-muted" for="remember">Keep me signed in</label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark rounded-pill py-2 fw-medium">Sign In</button>
                    </div>
                </form>

                <p class="text-center text-muted small mt-4 mb-0">
                    Don't have an account?
                    <a href="@Url.Action("Register","User")"
                       class="text-decoration-none fw-medium" style="color:#0071e3">Create one</a>
                </p>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<script>
$('#loginForm').on('submit', function (e) {
    e.preventDefault();

    var data = {
        Email: $('input[name=Email]').val(),
        Password: $('input[name=Password]').val()
    };

    $.ajax({
        url: '@loginUrl',
        type: 'POST',
        contentType: 'application/json; charset=utf-8',
        dataType: 'json',
        data: JSON.stringify(data),

        success: function (res) {

            if (res.success) {

                localStorage.setItem("token", res.accessToken);
                localStorage.setItem("user", JSON.stringify(res.user));

                alert("Login success");

                // Test protected route
                testProfileApi();
            }
            else {
                alert(res.message);
            }
        },

        error: function (xhr) {
            console.log(xhr);
            alert("Login failed");
        }
    });
});


function testProfileApi() {

    const token = localStorage.getItem("token");

    $.ajax({
        url: '@profileUrl',
        type: 'POST',

        headers: {
            "Authorization": "Bearer " + token
        },

        success: function (res) {
            console.log("Protected Route Success:", res);
            alert("JWT Guard Working");
        },

        error: function (error) {
            console.log(error);
            alert("JWT Guard Failed");
        }
    });
}
</script>